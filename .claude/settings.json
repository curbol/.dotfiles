{
  "effortLevel": "high",
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "gatekeeper@claude-watchtower": true,
    "github@claude-plugins-official": false,
    "gopls-lsp@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "notify@claude-watchtower": true,
    "superpowers@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "extraKnownMarketplaces": {
    "claude-watchtower": {
      "source": {
        "repo": "curbol/claude-watchtower",
        "source": "github"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "file=$(jq -r '.tool_input.file_path') && case \"$file\" in *.go) cd \"$CLAUDE_PROJECT_DIR\" && go build .\/... 2>&1 | head -20 ;; *.ts|*.tsx) cd \"$CLAUDE_PROJECT_DIR\" && tsc --noEmit 2>&1 | head -20 ;; esac",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(go *)",
      "Bash(make *)",
      "Bash(golangci-lint *)",
      "Bash(mise *)",
      "Bash(git status*)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git pull *)",
      "Bash(git add *)",
      "Bash(git stash *)",
      "Bash(git fetch *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git remote *)",
      "Bash(git switch *)",
      "Bash(gh *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(tsc *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(which *)",
      "Bash(brew *)",
      "Read(\/tmp\/**)",
      "Write(\/tmp\/**)",
      "Edit(\/tmp\/**)"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ]
  },
  "statusLine": {
    "command": "bash ~\/.claude\/statusline-command.sh",
    "type": "command"
  }
}
