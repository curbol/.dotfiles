{
  "permissions": {
    "allow": [
      "Bash(go *)",
      "Bash(make *)",
      "Bash(golangci-lint *)",
      "Bash(mise *)",
      "Bash(git:*)",
      "Bash(gh *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(tsc *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(which *)",
      "Bash(brew *)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(tilt:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "mcp__shortcut",
      "mcp__claude_ai_Notion",
      "Read(/tmp/**)",
      "Write(/tmp/**)",
      "Edit(/tmp/**)"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "/Users/curtis/code",
      "/home/curbol/code"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": false,
    "slack@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "work@gladly-claude-tools": true,
    "local-dev@gladly-claude-tools": true,
    "analyze-tests@gladly-claude-tools": false,
    "address-pr-comments@gladly-claude-tools": true,
    "test-deployed@gladly-claude-tools": true,
    "playwright@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "gladly-claude-tools": {
      "source": {
        "source": "github",
        "repo": "sagansystems/gladly-claude-tools"
      }
    }
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "autoDreamEnabled": true,
  "teammateMode": "auto",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
