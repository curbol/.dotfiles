{
  "permissions": {
    "allow": [
      "Bash(go *)",
      "Bash(make *)",
      "Bash(golangci-lint *)",
      "Bash(mise *)",
      "Bash(git:*)",
      "Bash(gh *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(tsc *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(which *)",
      "Bash(brew *)",
      "Read(/tmp/**)",
      "Write(/tmp/**)",
      "Edit(/tmp/**)"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(jq -r '.tool_input.file_path') && case \"$file\" in *.go) cd \"$CLAUDE_PROJECT_DIR\" && go build ./... 2>&1 | head -20 ;; *.ts|*.tsx) cd \"$CLAUDE_PROJECT_DIR\" && tsc --noEmit 2>&1 | head -20 ;; esac"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "gatekeeper@claude-watchtower": true,
    "gopls-lsp@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "notify@claude-watchtower": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-watchtower": {
      "source": {
        "source": "github",
        "repo": "curbol/claude-watchtower"
      }
    }
  }
}
