# Theme — Mac uses dotfiles theme.conf; Linux uses omarchy (overrides below)
config-file = ?"~/.config/ghostty/theme.conf"
config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"

# Font
font-family = "Maple Mono NF"
font-style = Regular
font-size = 10

# Window
window-padding-x = 14
window-padding-y = 14
macos-titlebar-style = hidden
confirm-close-surface = false
resize-overlay = never

# Linux/GTK (ignored on Mac)
window-theme = ghostty
gtk-toolbar-style = flat

# Cursor
cursor-style = block
cursor-style-blink = false

# Shell integration (preserves SSH terminfo; disables cursor override)
shell-integration-features = no-cursor,ssh-env

# Mouse
mouse-scroll-multiplier = 0.95

# Send Option as Alt/Meta so tmux M- bindings work (e.g. M-Left/Right for windows)
macos-option-as-alt = left

# Linux-only overrides (e.g. async-backend for Hyprland slowness fix)
config-file = ?"~/.config/ghostty/linux.conf"

# Clipboard
keybind = shift+insert=paste_from_clipboard
keybind = control+insert=copy_to_clipboard

# Pane resize
keybind = super+ctrl+shift+alt+arrow_down=resize_split:down,100
keybind = super+ctrl+shift+alt+arrow_up=resize_split:up,100
keybind = super+ctrl+shift+alt+arrow_left=resize_split:left,100
keybind = super+ctrl+shift+alt+arrow_right=resize_split:right,100

# Shift+Enter fix for Claude Code inside tmux
keybind = shift+enter=text:\x1b\r
